# Telegram publishing (optional)
TELEGRAM_ENABLE=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@your_channel_or_numeric_id
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_DISABLE_NOTIFICATIONS=true
TELEGRAM_MAX_ITEMS=10
TELEGRAM_STREAM=false

# OpenRouter API (for summaries)
OPENROUTER_API_KEY=

# Summarization language
SUMMARY_LANG=ru

# Data collection settings
TOP_N=40
TOP_N_MODE=topstories
# After migrate-to-sqlite backfill, set true to aggregate from data/hn.sqlite
AGGREGATE_FROM_DB=false
# Per-attempt LLM usage accounting into llm_usage. Before enabling in production, create the
# table on the remote D1 (idempotent, applies only this change — NOT `d1 migrations apply`):
#   bunx wrangler d1 execute hn_distill --remote --file worker/d1/migrations/005_llm_usage.sql
LLM_USAGE_ENABLED=false
TOP_N_DAY_OFFSET=0
MAX_COMMENTS_PER_STORY=40
MAX_DEPTH=2
CONCURRENCY=8

# Article processing limits
ARTICLE_SLICE_CHARS=6000
# Head+tail slice: keep the first ARTICLE_HEAD_CHARS, then the last
# (ARTICLE_SLICE_CHARS - ARTICLE_HEAD_CHARS) so long-article conclusions survive.
ARTICLE_HEAD_CHARS=4000
MAX_BODY_CHARS=2000

# HTML extract garbage detector (utils/extract-quality.ts). HTML that is nav/
# boilerplate/link-farm is flagged `no-article`: the post LLM is skipped and only
# comments are summarized. Thresholds: flag when prose is too thin OR links /
# duplicate lines dominate. PDFs, YouTube transcripts and plaintext bypass this.
EXTRACT_MIN_PROSE_CHARS=500
EXTRACT_MAX_LINK_DENSITY=0.5
EXTRACT_MAX_DUP_RATIO=0.5

# Cloudflare / bot-block article fetch fallback via Jina Reader (r.jina.ai).
# On 403 / JS-challenge the pipeline retries as https://r.jina.ai/<url> and
# caches markdown with source_kind=reader. Free tier works without a key
# (~20 RPM); set JINA_API_KEY for higher limits. Set false to disable.
ARTICLE_FETCH_READER_FALLBACK=true
JINA_API_KEY=
# ARTICLE_READER_BASE_URL=https://r.jina.ai

# HTTP settings
HTTP_TIMEOUT_MS=15000
HTTP_RETRIES=3
HTTP_BACKOFF_MS=600

# AI model settings
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODEL_2=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MAX_TOKENS=8000

# Comments-v2 budgets. Three 7s calls fit the worker's default 25s task budget;
# production also clamps each request to the task's remaining deadline.
COMMENTS_SUMMARY_MIN_CHARS=200
COMMENTS_MIN_CYRILLIC_RATIO=0.65
COMMENTS_PROMPT_MAX_CHARS=24000
# Room for up to 15 RU insights (dynamic ceiling).
COMMENTS_SUMMARY_MAX_TOKENS=2500
COMMENTS_MAX_LLM_CALLS=3
COMMENTS_LLM_REQUEST_TIMEOUT_MS=7000
# Must be >= COMMENTS_PROMPT_MAX_CHARS so the judge sees the candidate context.
COMMENTS_JUDGE_THREAD_MAX_CHARS=24000
# Second-pass compression of structured comments (paid OpenRouter). Empty = off.
# Changing the model does NOT invalidate existing compressed results — bump
# COMMENTS_COMPRESS_POLICY_VERSION in config/env.ts to force recompression.
COMMENTS_COMPRESS_MODEL=qwen/qwen3-next-80b-a3b-instruct
COMMENTS_COMPRESS_MAX_TOKENS=1000
# Comments-v2 Groq chain + paid OpenRouter last resort (see config/env.ts).
# COMMENTS_MODEL=llama-3.3-70b-versatile
# COMMENTS_FALLBACK_MODEL=llama-3.1-8b-instant
# COMMENTS_FALLBACK_MODEL_2=
# COMMENTS_OPENROUTER_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct
# Phase 3 scaffold (DEFAULT OFF). Size-aware second Groq hop: short→8b, medium→Qwen 27b.
# Do not enable in prod until Phase 2 PASS / explicit waiver + Phase 4 rollout plan.
# COMMENTS_QWEN27B_ROUTE_ENABLE=false
# COMMENTS_QWEN27B_MODEL=qwen/qwen3.6-27b
# COMMENTS_SHORT_ROUTE_MAX_RESERVED_TOKENS=5500
# COMMENTS_QWEN27B_MAX_RESERVED_TOKENS=8000

# Tagging + post-guard (Groq strict JSON when GROQ_API_KEY is set).
TAGS_MODEL=openai/gpt-oss-20b
TAGS_MAX_TOKENS=512
TAGS_LANG=en
TAGS_MAX_PER_STORY=10
POST_GUARD_ENABLE=true
POST_GUARD_MODEL=openai/gpt-oss-20b
# Empty = one guard attempt then heuristics-only (no unverified second model).
POST_GUARD_FALLBACK_MODEL=
POST_GUARD_MAX_TOKENS=256

# Logging
LOG_LEVEL=info

# Site settings
SITE=
BASE=
# Optional: GoatCounter subdomain code. When set, a cookieless pageview script is injected
# into the built site (dashboard at https://<code>.goatcounter.com). Leave empty in dev.
# GOATCOUNTER_CODE=hn-distill

# RU language-purity gate (retry-only; see docs/language-gate-calibration.md)
SUMMARY_LANGUAGE_GATE_ENABLE=true
SUMMARY_MIN_CYRILLIC_RATIO=0.8
SUMMARY_LATIN_SOFT_RUNS=false
SUMMARY_LATIN_SINGLETONS=true
# Escalation model for content-rejected summaries (strict retries start here).
# Paid OpenRouter route validated in docs/escalation-model-bench.md; empty keeps the default chain.
SUMMARY_CONTENT_REJECT_MODEL=qwen/qwen3-next-80b-a3b-instruct

# Summarization workload controls
SUMMARIZE_MAX_STORIES_PER_RUN=500
SUMMARIZE_COOLDOWN_MINUTES=0
POST_SUMMARY_ONLY_IF_MISSING=false

# Worker-only, opt-in Readability migration. Drains legacy article_extract rows
# outside the current TOP_N in bounded cron batches; disable after the count is 0.
WORKER_EXTRACTION_BACKFILL_ENABLE=false

# PDF parsing limits
PDF_MAX_PAGES=12
PDF_MAX_BYTES=10000000

# YouTube transcript preferences
YT_TRANSCRIPT_LANGS=

# Offline model scoring (data:score) — paid judge calls scale with candidates × articles × repeats
# Required for a real run (or use --stub-judge). Set to your flagship judge model id.
JUDGE_MODEL=
JUDGE_MAX_TOKENS=700
# JUDGE_API_KEY=
# JUDGE_BASE_URL=
# Judge must see the same slice the candidate summarized; keep >= ARTICLE_SLICE_CHARS.
JUDGE_ARTICLE_MAX_CHARS=6000
BENCH_REPEATS=1
BENCH_CONCURRENCY=2
BENCH_MAX_ARTICLES=30
# Free models often need >15s per summary; bench uses max(HTTP_TIMEOUT_MS, this)
BENCH_HTTP_TIMEOUT_MS=180000
# max_tokens for candidate summaries. Keep low: a summary needs ~500 tokens, and on Groq free
# tier requested max_tokens counts toward the per-request TPM cap (qwen3-32b=6000) → 413 if too high.
BENCH_SUMMARY_MAX_TOKENS=2048
