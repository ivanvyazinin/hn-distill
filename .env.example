# optional: used by summarize step; if empty, summaries are skipped
OPENROUTER_API_KEY=

# defaults for data generation
SUMMARY_LANG=ru
TOP_N=40
MAX_COMMENTS_PER_STORY=40
MAX_DEPTH=2
CONCURRENCY=8

# networking controls (timeouts/retries/backoff for HTTP requests)
# global request timeout in milliseconds (1000-60000)
HTTP_TIMEOUT_MS=15000
HTTP_RETRIES=3
HTTP_BACKOFF_MS=600

# OpenRouter LLM settings
# default model to use for chat completions
OPENROUTER_MODEL=openrouter/horizon-beta
OPENROUTER_MAX_TOKENS=16000

# summarization workload caps
# hard cap on how many stories to summarize per run (1-500)
SUMMARIZE_MAX_STORIES_PER_RUN=500
# cooldown window in minutes to avoid re-summarizing too frequently (0 disables)
SUMMARIZE_COOLDOWN_MINUTES=0

# never update post summaries if they already exist (saves tokens)
POST_SUMMARY_ONLY_IF_MISSING=true

# logging level: silent | error | warn | info | debug
LOG_LEVEL=info

# content limits
ARTICLE_SLICE_CHARS=6000
MAX_BODY_CHARS=2000

# site build
SITE=
BASE=/
