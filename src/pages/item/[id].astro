---
// src/pages/item/[id].astro
import Analytics from "../../components/Analytics.astro";
import { LANG } from "@config/lang";
import { PATHS } from "@config/paths";
import type { AggregatedItem } from "@config/schemas";
import { commentsFoldLabel } from "@utils/comments-render";
import { formatDateHuman } from "@utils/date";
import { loadAggregated } from "@utils/load-aggregated";
import { mdToHtml } from "@utils/md-to-html";
import type { GetStaticPaths } from "astro";
import "../../styles/global.css";
import { TAG_MIN_COUNT } from "@config/constants";
import { countTags } from "@utils/tag-counts";
import { withBase } from "../../utils/base";

export const getStaticPaths: GetStaticPaths = async () => {
  const { items } = loadAggregated(PATHS.aggregated);
  return (items ?? []).map((it) => ({ params: { id: String(it.id) } }));
};

const lang = LANG;
const { id: idParam } = Astro.params as { id: string };
const id = Number(idParam);
const { items } = loadAggregated(PATHS.aggregated);
const item = (items as AggregatedItem[]).find((x) => x.id === id);

if (!item) throw new Error("Missing item for id " + id);

const tags = Array.isArray(item.tags) ? item.tags : [];
const countsMap = countTags(items);

function tagHref(tag: string): string {
  const c = countsMap.get(tag) ?? 0;
  return c >= TAG_MIN_COUNT ? withBase(`tag/${encodeURIComponent(tag)}/`) : `${withBase("search/")}?tags=${encodeURIComponent(tag)}`;
}

const postMd = item.postSummary ?? "";
const commentsMd = item.commentsSummary ?? "";
const parts = item.commentsInsights;
const visibleMd = parts
  ? [parts.lead.trimEnd(), parts.visible.trimEnd()].filter((chunk) => chunk.length > 0).join("\n\n")
  : commentsMd;
const postHtml = postMd ? mdToHtml(postMd) : "";
const commentsHtml = visibleMd ? mdToHtml(visibleMd) : "";
const foldedHtml = parts?.folded ? mdToHtml(parts.folded) : "";
const datePretty = formatDateHuman(item.timeISO);
const hnUrl = item.hnUrl ?? `https://news.ycombinator.com/item?id=${item.id}`;

const description = (postMd || commentsMd || `Hacker News discussion for: ${item.title}`).slice(0, 300);

const i18n = {
  ru: {
    comments: "Комментарии",
  },
  en: {
    comments: "Comments",
  },
};
const t = i18n[lang];
const commentsLabel = typeof item.commentsCount === "number" ? ` (${item.commentsCount})` : "";
const foldLabel = parts === undefined ? "" : commentsFoldLabel(parts, lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>{item.title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:title" content={item.title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Hacker News Digest" />
    <meta property="og:type" content="article" />
    <link rel="canonical" href={hnUrl} />
    <Analytics />
  </head>
  <body>
    <header>
      <h1><a href={withBase("")}>Hacker News Digest</a></h1>
      <p class="meta">
        {datePretty} • {item.domain ?? "news.ycombinator.com"} • ⭐ {item.score ?? 0} • 💬 {item.commentsCount ?? 0}
      </p>
      <p class="meta"><a href={item.url ?? hnUrl} rel="noopener noreferrer">Original</a> • <a href={hnUrl}>HN</a></p>
      {tags.length > 0 && (
        <p class="meta tags">
          {tags.map((tag) => <a href={tagHref(tag)} class="tag">#{tag}</a>)}
        </p>
      )}
    </header>
    <main>
      <section class="grid2">
        <div class="card">
          <h2 class="title">{item.title}</h2>
          {postHtml ? <div class="md" set:html={postHtml} /> : <p class="meta">No post summary.</p>}
        </div>
        <aside class="card">
          <h3 class="title">
            <a href={hnUrl} target="_blank" rel="noopener noreferrer nofollow">{t.comments}{commentsLabel}</a>
          </h3>
          {commentsHtml ? (
            <>
              <div class="md" set:html={commentsHtml} />
              {foldedHtml && (
                <details class="md-fold">
                  <summary>{foldLabel}</summary>
                  <div class="md" set:html={foldedHtml} />
                </details>
              )}
            </>
          ) : (
            <p class="meta">No comments summary.</p>
          )}
        </aside>
      </section>
    </main>
  </body>
</html>
