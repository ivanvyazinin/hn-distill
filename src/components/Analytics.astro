---
import { env } from "@config/env";

// GoatCounter pageview analytics. Rendered only when GOATCOUNTER_CODE is set at build time
// (see config/env.ts). Cookieless, no consent banner; counts by location.pathname so the
// configured base path is handled automatically.
const code = env.GOATCOUNTER_CODE;
---

{
  code && (
    <script
      data-goatcounter={`https://${code}.goatcounter.com/count`}
      async
      src="//gc.zgo.at/count.js"
    />
  )
}
