---
import { HOT_SCORE_THRESHOLD, LONG_DISCUSSION_THRESHOLD, TAG_MIN_COUNT } from "@config/constants";
import { LANG } from "@config/lang";
import type { AggregatedItem } from "@config/schemas";
import { formatDateHuman } from "@utils/date";
import { mdToHtml } from "@utils/md-to-html";
import { withBase } from "../utils/base";

const { item, tagCounts } = Astro.props as {
  item: AggregatedItem;
  tagCounts?: Record<string, number>;
};
const lang = LANG;
const tags = Array.isArray(item.tags) ? item.tags : [];

function storyHref(id: number): string {
  return withBase(`item/${id}/`);
}

function tagHref(tag: string): string {
  const c = tagCounts?.[tag] ?? 0;
  return c >= TAG_MIN_COUNT ? withBase(`tag/${encodeURIComponent(tag)}/`) : `${withBase("search/")}?tags=${encodeURIComponent(tag)}`;
}

const safeTitle = item.title || "(no title)";
const safeBy = item.by || "unknown";
const safeTime = item.timeISO ? formatDateHuman(item.timeISO) : "—";
const pts = typeof item.score === "number" ? ` • ${item.score} points` : "";
const commentsLabel = typeof item.commentsCount === "number" ? ` (${item.commentsCount})` : "";
const hnUrl = item.hnUrl ?? `https://news.ycombinator.com/item?id=${item.id}`;

const commentsCount = typeof item.commentsCount === "number" ? item.commentsCount : 0;
const score = typeof item.score === "number" ? item.score : 0;
const isLongDiscussion = commentsCount > LONG_DISCUSSION_THRESHOLD;
const isHot = score > HOT_SCORE_THRESHOLD;

const i18n = {
  ru: {
    comments: "Комментарии",
    hot: "Горячее",
    long: "Длинная дискуссия",
    original: "Оригинал",
    moreTakeaways: (n: number) => {
      if (n === 0) return "цитата из треда";
      if (n === 1) return "ещё 1 тезис";
      return `ещё ${n} тезиса`;
    },
    moreWithQuote: (n: number) => {
      if (n === 0) return "цитата из треда";
      if (n === 1) return "ещё 1 тезис (+ и цитата)";
      return `ещё ${n} тезиса (+ и цитата)`;
    },
  },
  en: {
    comments: "Comments",
    hot: "Hot",
    long: "Long discussion",
    original: "Original",
    moreTakeaways: (n: number) => (n === 0 ? "quote from the thread" : `${n} more takeaways`),
    moreWithQuote: (n: number) =>
      n === 0 ? "quote from the thread" : `${n} more takeaways (+ quote)`,
  },
};
const t = i18n[lang];

const postHtml = item.postSummary ? mdToHtml(item.postSummary) : "";
const parts = item.commentsInsights;
const visibleMd = parts
  ? [parts.lead.trimEnd(), parts.visible.trimEnd()].filter((chunk) => chunk.length > 0).join("\n\n")
  : item.commentsSummary ?? "";
const commentsHtml = visibleMd ? mdToHtml(visibleMd) : "";
const foldedHtml = parts?.folded ? mdToHtml(parts.folded) : "";
const hasQuoteInFold = Boolean(parts?.folded && parts.folded.includes("> "));
const foldLabel =
  parts === undefined
    ? ""
    : hasQuoteInFold
      ? t.moreWithQuote(parts.foldedInsightsCount)
      : t.moreTakeaways(parts.foldedInsightsCount);
---

<section
  class="grid2 js-card"
  aria-labelledby={`t-${item.id}`}
  tabindex="-1"
  data-original={item.url ?? hnUrl}
>
  <div class="card">
    <h2 id={`t-${item.id}`} class="title">
      <a href={storyHref(item.id)}>{safeTitle}</a>
      {
        item.domain && (
          <span class="meta" style="font-weight: normal; margin-left: 0.5rem;">
            ({item.domain})
          </span>
        )
      }
      {
        (isHot || isLongDiscussion) && (
          <span class="badges">
            {isHot && <span class="badge badge--hot">🔥 {t.hot}</span>}
            {isLongDiscussion && <span class="badge badge--long">💬 {t.long}</span>}
          </span>
        )
      }
    </h2>
    {postHtml ? <div class="md" set:html={postHtml} /> : <p>—</p>}
    <p class="meta">by {safeBy} • {safeTime}{pts}</p>
    <p class="meta"><a href={item.url ?? hnUrl} target="_blank" rel="noopener noreferrer nofollow">{t.original}</a> • <a href={hnUrl} target="_blank" rel="noopener noreferrer nofollow">HN</a></p>
    {tags.length > 0 && (
      <p class="meta tags">
        {tags.map((tag) => <a href={tagHref(tag)} class="tag">#{tag}</a>)}
      </p>
    )}
  </div>
  <div class="card">
    <h3 class="title">
      <a href={hnUrl} target="_blank" rel="noopener noreferrer nofollow">{t.comments}{commentsLabel}</a>
    </h3>
    {commentsHtml ? (
      <>
        <div class="md" set:html={commentsHtml} />
        {foldedHtml && (
          <details class="md-fold">
            <summary>{foldLabel}</summary>
            <div class="md" set:html={foldedHtml} />
          </details>
        )}
      </>
    ) : (
      <p>—</p>
    )}
  </div>
</section>
